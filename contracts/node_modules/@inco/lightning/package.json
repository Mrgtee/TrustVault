{
  "name": "@inco/lightning",
  "version": "0.7.12",
  "repository": "https://github.com/Inco-fhevm/inco-monorepo",
  "files": [
    "src/",
    "dumps/",
    "CHANGELOG.md",
    "manifest.yaml"
  ],
  "scripts": {
    "lint": "forge lint && forge fmt --check",
    "lint:fix": "forge fmt",
    "generate": "bun run generate:libraries",
    "generate:libraries": "bun run ../pega/lib/deployment/cmd/generate-libraries.ts",
    "publish:github": "bun publish --registry=https://npm.pkg.github.com",
    "publish:npm": "bun publish --access public"
  },
  "dependencies": {
    "@inco/shared": "^0.1.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@openzeppelin/contracts-upgradeable": "^5.2.0",
    "@safe-global/safe-smart-account": "https://github.com/safe-global/safe-smart-account.git#v1.5.0",
    "ds-test": "https://github.com/dapphub/ds-test",
    "forge-std": "https://github.com/foundry-rs/forge-std",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lcov-badge2": "^1.1.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
